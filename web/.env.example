# Abby's Table — storefront environment
#
# Copy to `.env.local` (git-ignored) and fill in for live data. With nothing set,
# the storefront runs entirely on demo fixtures — no network, no tenant needed.
#
# Every variable here is SERVER-ONLY. None may be prefixed `NEXT_PUBLIC_`:
# that would bundle it into client JavaScript and publish it.

# ---------------------------------------------------------------------------
# Data mode — demo | live
# ---------------------------------------------------------------------------
# demo  the design-template fixtures. Deterministic, offline, no tenant.
# live  the real Aonik commerce API (requires the two variables below).
#
# Unset means: live when AONIK_API_URL is set, demo otherwise.
#
# In DEVELOPMENT this is only the default — the floating badge in the corner
# switches modes per-browser via a cookie, no restart needed. In PRODUCTION the
# cookie is ignored entirely and this value (or the fallback above) decides.
AONIK_DATA_MODE=demo

# ---------------------------------------------------------------------------
# Aonik connection — required for live mode
# ---------------------------------------------------------------------------
# Base URL, no trailing slash. Every storefront route sits under /commerce/...
AONIK_API_URL=https://localhost:7218

# The tenant GUID this storefront reads. Aonik partitions all commerce data by
# tenant and varies its shared caches on this header, so a base URL without a
# tenant is not a usable configuration — set both or neither.
#
# AbbysTable is ONE tenant of a multi-tenant platform (Aonik ADR-013): nothing
# in this repo may assume it is the only storefront Aonik serves.
AONIK_TENANT_ID=

# ---------------------------------------------------------------------------
# Deliberately absent
# ---------------------------------------------------------------------------
# There is no AONIK_API_KEY. Aonik's storefront surface is anonymous — catalog
# reads take no credential at all, cart calls prove possession with a per-cart
# token, and customer calls use the signed-in session. A static service key
# would be both useless and a liability.
